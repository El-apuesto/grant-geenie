{
  "version": 2,
  "builds": [
    {
      "src": "blog/**",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "_site"
      }
    },
    {
      "src": "package.json",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/blog/(.*)",
      "dest": "/blog/$1"
    }
  ]
}